" <Leader>キー
let mapleader = " "

" シンタックスを有効化
syntax enable
" jj
imap <silent> jj <ESC>
" 折り返し時に表示行単位での移動できるようにする
nmap j gj
nmap k gk
" デフォルトをutf-8
set encoding=utf-8
"文字コードをUFT-8に設定
set fenc=utf-8
" バックアップファイルを作らない
set nobackup
" スワップファイルを作らない
set noswapfile
" 編集中のファイルが変更されたら自動で読み直す
set autoread
" バッファが編集中でもその他のファイルを開けるように
set hidden
" 入力中のコマンドをステータスに表示する
set showcmd
" ヤンクをクリップボードへ
set clipboard&
set clipboard^=unnamedplus
" タブ文字の表示幅を空白2個分にする
set tabstop=2
" タブ文字の表示幅を空白2個分にする（インデントの増減に対応）
set shiftwidth=2

" editor window split
nnoremap ss <C-w>s
nnoremap sv <C-w>v

" editor window move
nnoremap sh <C-w>h
nnoremap sj <C-w>j
nnoremap sk <C-w>k
nnoremap sl <C-w>l

set easymotion
set surround
set commentary
set ideajoin
set highlightedyank

nmap <leader>fa <Action>(GotoAction)
nmap <leader>ff <Action>(SearchEverywhere)
nmap <leader>fw <Action>(FindInPath)
nmap <leader>fs <Action>(FindSymbol)
nmap <leader>fr <Action>(RecentFiles)
nmap <leader>fc <Action>(FindClass)
nmap <leader>fe <Action>(FindFile)
nmap <leader>fn <Action>(FindInFiles)
nmap <leader>fp <Action>(FindInPath)

